[global_config]
  borderless = True
  extra_styling = False
  tab_position = hidden
[keybindings]
[layouts]
  [[default]]
    [[[child1]]]
      parent = window0
      type = Terminal
    [[[window0]]]
      parent = ""
      type = Window
[plugins]
[profiles]
  [[default]]
    background_darkness = 0.77
    background_type = transparent
    background_color = #70000000
    cursor_color = "#aaaaaa"
    foreground_color = ""
    icon_bell = False
    scrollbar_position = hidden
    show_titlebar = False
